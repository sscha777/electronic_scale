	ESP_LOGI(TAG, "mem_hg_bowl_addr = 0x%x", mem_hg_bowl_addr);

	mem_hg_unreg_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_UNREG));
