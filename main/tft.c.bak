static void (*Touch_Callback)(INTRO_EVENTS event) = 0;
static void (*init_callback)(UI_INIT_EVENT event) = 0;
static void (*unRegCallback)(MSG_UN_REG event) = 0;
static void (*startCallback)(MSG_START event) = 0;

/* check for touch events and setup vars for TFT_display() */
uint8_t TouchInput(void)
{
	uint8_t tag;

	if (EVE_busy()) /* is EVE still processing the last display list? */
	{
		return (0);
	}

	tag = EVE_memRead8(REG_TOUCH_TAG); /* read the value for the first touch point */

	return (tag);
}

void TFT_init(void)
{
	if (EVE_init() != 0)
	{
		tft_active = 1;
		ESP_LOGI(TAG, "TFT Init OK!\n");
		// EVE_memWrite8(REG_PWM_DUTY, 0x30); /* setup backlight, range is from 0 = off to 0x80 = max */
		EVE_memWrite8(REG_PWM_DUTY, 0x80); /* setup backlight, range is from 0 = off to 0x80 = max */
	}
}
/**
 * @brief home screen gui
 *
 * @param touchcallback
 * @param closefunction
 * @return void*
 */
// void *scaleHome(void (*touchcallback)(), void (**closefunction)())
void *scaleHome(void (*touchcallback)())
{
	guiHome();
	Touch_Callback = touchcallback;
	return homeScreenLoop;
}

void homeScreenLoop()
{
	uint8_t TouchTag = TouchInput();
	uint8_t startKey;

	static uint8_t preTag = 0;
	static uint8_t tagFlag = 0;
	static uint8_t prevStartKey = 0; /* ext. key read */

	tftTouchTag = TouchTag;
	if (preTag != TouchTag)
	{
		if (TouchTag == 0)
		{
			tagFlag = 1;
		}
		else
		{
			preTag = TouchTag;
		}
	}

	/*ext  key input */
	if (scaleInfo.scale_mode == W_MINUS_SCALE_MODE)
	{
		startKey = gpio_get_level(GPIO_NUM_2);

		if (startKey != prevStartKey)
		{
			prevStartKey = startKey;
			if (startKey)
			{
				tagFlag = 1;
				TouchTag = SCALE_START;
				preTag = TouchTag;
				ESP_LOGI(TAG, "press start key!(%d)", startKey);
			}
			else
			{
				tagFlag = 0;
			}
		}
	}

	if (TouchTag >= WIFI_SCAN && TouchTag <= SCALE_RESET && tagFlag)
	{
		ESP_LOGI(TAG, "TOUCH(%d)", TouchTag);
		(*Touch_Callback)(preTag);
		preTag = 0;
	}

	guiHome();
}

/**
 * @brief 휘도 밝기 테스트용
 *
 */
void whiteScreen(void)
{
	EVE_start_cmd_burst();	 /* start writing to the cmd-fifo as one stream of bytes, only sending the address once */
	EVE_cmd_dl(CMD_DLSTART); /* start the display list */
	EVE_cmd_dl(VERTEX_FORMAT(0));

	EVE_cmd_dl(DL_CLEAR_RGB | WHITE);					/* set the default clear color to white */
	EVE_cmd_dl(DL_CLEAR | CLR_COL | CLR_STN | CLR_TAG); /* clear the screen - this and the previous prevent artifacts between lists, Attributes are the color, stencil and tag buffers */
	EVE_color_rgb(255, 255, 255);
	EVE_cmd_dl(DL_CLEAR_RGB | WHITE); /* set the default clear color to white */
	EVE_cmd_dl(DL_END);

	EVE_cmd_dl(DL_DISPLAY); /* instruct the graphics processor to show the list */
	EVE_cmd_dl(CMD_SWAP);	/* make this list active */

	EVE_end_cmd_burst(); /* stop writing to the cmd-fifo */
	EVE_cmd_start();	 /* order the command co-processor to start processing its FIFO queue but do not wait for completion */
}

void guiHomeTouchCallback(HOME_EVENTS event)
{
	// static char soundTestcnt = 0;
	switch (event)
	{
	case WIFI_SCAN:
		if (!scaleInfo.ethernetConnect)
		{
			newScenario = WIFI_SCAN_SCNARIO;
			ESP_LOGI(TAG, "wifi scan menu");
		}
		break;
	case SCALE_START:
		if (taskInfo.work_step >= W_WAITING_START)
		{
			newScenario = MSG_START_SCNARIO;
			ESP_LOGI(TAG, "smart scale strart!");
		}
		break;
	case SCALE_CAL:
		newScenario = CALIBRATION_SCNARIO;
		ESP_LOGI(TAG, "scale cal menu");
		break;
	case FAIL_WEIGHT:
		ESP_LOGI(TAG, "fail weight regist");
		newScenario = FAILWEIGHT_SCENARIO;
		break;
	case SCALE_RESET:
		ESP_LOGI(TAG, "scale reset");
		newScenario = MSG_INIT_SCNARIO;
		// whiteScreen();
		// DELAY_MS(10000);
		break;
	default:
		ESP_LOGI(TAG, "home scr event");
		break;
	}

	if (event >= WIFI_SCAN && event <= SCALE_RESET)
	{
		EVE_sound_play(AUDIO_CLICK, AUDIO_VOLUME);
		// EVE_sound_play(soundTestcnt++, AUDIO_VOLUME);
		// ESP_LOGI(TAG,"%d",soundTestcnt);
	}
}

void sendLevelLed(int32_t g)
{
	float tmp2 = (float)(taskInfo.target_weight * 10 / 9);
	float tmp3 = (float)((g * 10 / tmp2) / 2);

	if (tmp3 >= 8)
	{
		tmp3 = 8; // 최대
	}
	else if (g < 3)
	{
		tmp3 = 9; // 꺼짐
	}
	if (taskInfo.min_weight >= g && taskInfo.max_weight <= g)
	{
		tmp3 = 4; // 중간
	}
	sendLedDisp((uint8_t)tmp3, 10);
}

#define ONE_LINE_COLOR 50
#define HIGH_LINE_COLOR 250
#define GRAY_TEXT_COLOR 0x7f
#define BUTTON_X 750
/**
 * @brief M0 -, M1 =, m2 |, m3|| , M4 twoline
 *
 */
#define START_LINE_X 0
#define END_LINE_X 799
#define M0_LINE_Y 110
#define M1_LINE_Y 410
#define M2_LINE_X 280
#define M3_LINE_X 740
#define M4_LINE_Y 320

/* LED */
void sendSeqLed(uint32_t cnt, uint32_t total)
{
	// led 1,2,3,4,5(all) -> 4,10,11,12,13
	uint32_t step[5] = {4, 10, 11, 12, 13};
	uint32_t tmp, tmp1;
	tmp = total / 5; // 단계 5
	tmp1 = cnt / tmp;
	if (tmp1 > 4)
		tmp1 = 4;
	sendLedDisp(step[tmp1], 10);
	// ESP_LOGE(TAG, "LED %d %d[%d]", tmp, tmp1, step[tmp1]);
}

/* LED */
void sendSeqLed_plus(uint32_t cnt, uint32_t total)
{
	// led 1,2,3,4,5(all) -> 4,10,11,12,13
	uint32_t step[5] = {4, 10, 11, 12, 13};
	uint32_t tmp, tmp1;
	tmp = total / 4; // 단계 5
	tmp1 = cnt / tmp;
	if (tmp1 >= 2)
		tmp1 = 2;
	sendLedDisp(step[tmp1], 10);
	// ESP_LOGE(TAG, "LED %d %d[%d]", tmp, tmp1, step[tmp1]);
}

void guiHome(void)
{
	static int64_t cheatCount = 0;
	static int32_t cheat_g = 0;
	struct tm disp_time;
	uint32_t calc;
	uint16_t old_offset, new_offset;
	// uint16_t display_list_size;
	static int32_t work_min = 0, work_hours = 0, worktime_start_min = 0, worktime_start_hour = 0;
	static uint32_t weight_cont_count = 0;
	char str[10] = {
		0,
	};
	static char prev_work_name[TASK_NAME_LENGTH] = {
		0,
	};
	static char prev_worker_name[TASK_NAME_LENGTH] = {
		0,
	};
	float curGram = 0;
	int32_t intGram = 0;
	float fGram = 0;
	int32_t gDiff = 0;
	float fDiff = 0;
	float dispTotalw = 0;

	// ESP_LOGI(TAG, "t(%d)", _1sec_count);

	if (tft_active != 0)
	{

		/* 시퀜스 바뀌면 리셋 */
		if (taskInfo.seqChangeFlag == 1 && taskInfo.work_step > W_WAITING_START)
		{
			taskInfo.seqChangeFlag = 0;
			newScenario = MSG_INIT_SCNARIO;
		}

		if (taskInfo.work_step == W_TAGGING)
		{
			taskInfo.work_step = NO_JOB;
			EVE_sound_play(AUDIO_TAG_CLK, AUDIO_VOLUME);
		}
		old_offset = EVE_report_cmdoffset(); /* used to calculate the amount of cmd-fifo bytes necessary */
		// display_list_size = EVE_memRead16(REG_CMD_DL);

		EVE_start_cmd_burst();	 /* start writing to the cmd-fifo as one stream of bytes, only sending the address once */
		EVE_cmd_dl(CMD_DLSTART); /* start the display list */
		EVE_cmd_dl(VERTEX_FORMAT(0));

		EVE_cmd_dl(DL_CLEAR_RGB | BLACK);					/* set the default clear color to white */
		EVE_cmd_dl(DL_CLEAR | CLR_COL | CLR_STN | CLR_TAG); /* clear the screen - this and the previous prevent artifacts between lists, Attributes are the color, stencil and tag buffers */
		EVE_cmd_dl(TAG(0));									/* no touch */

		EVE_cmd_append(MEM_DL_STATIC, num_dl_static); /* insert static part of display-list from copy in gfx-mem */

		EVE_color_rgb(ONE_LINE_COLOR, ONE_LINE_COLOR, ONE_LINE_COLOR);
		EVE_cmd_dl(LINE_WIDTH(1 * 16));
		EVE_cmd_dl(DL_BEGIN | EVE_LINES);
		EVE_cmd_dl(VERTEX2F(START_LINE_X, M0_LINE_Y));
		EVE_cmd_dl(VERTEX2F(END_LINE_X, M0_LINE_Y));
		EVE_cmd_dl(DL_END);

		EVE_color_rgb(ONE_LINE_COLOR, ONE_LINE_COLOR, ONE_LINE_COLOR);
		EVE_cmd_dl(LINE_WIDTH(1 * 16));
		EVE_cmd_dl(DL_BEGIN | EVE_LINES);
		EVE_cmd_dl(VERTEX2F(START_LINE_X, M1_LINE_Y));
		EVE_cmd_dl(VERTEX2F(END_LINE_X, M1_LINE_Y));
		EVE_cmd_dl(DL_END);

		EVE_color_rgb(ONE_LINE_COLOR, ONE_LINE_COLOR, ONE_LINE_COLOR);
		EVE_cmd_dl(LINE_WIDTH(1 * 16));
		EVE_cmd_dl(DL_BEGIN | EVE_LINES);
		EVE_cmd_dl(VERTEX2F(M2_LINE_X, 0));
		EVE_cmd_dl(VERTEX2F(M2_LINE_X, 479));
		EVE_cmd_dl(DL_END);

		EVE_color_rgb(ONE_LINE_COLOR, ONE_LINE_COLOR, ONE_LINE_COLOR);
		EVE_cmd_dl(LINE_WIDTH(1 * 16));
		EVE_cmd_dl(DL_BEGIN | EVE_LINES);
		EVE_cmd_dl(VERTEX2F(M3_LINE_X, 0));
		EVE_cmd_dl(VERTEX2F(M3_LINE_X, 479));
		EVE_cmd_dl(DL_END);

		EVE_color_rgb(HIGH_LINE_COLOR, HIGH_LINE_COLOR, HIGH_LINE_COLOR);
		EVE_cmd_dl(LINE_WIDTH(2 * 16));
		EVE_cmd_dl(DL_BEGIN | EVE_LINES);
		EVE_cmd_dl(VERTEX2F(M2_LINE_X, M4_LINE_Y));
		EVE_cmd_dl(VERTEX2F(M3_LINE_X, M4_LINE_Y));
		EVE_cmd_dl(DL_END);

		/* 작업자 */
		EVE_cmd_dl(TAG(0));
		EVE_color_rgb(255, 255, 255);

		if (taskInfo.workerRegister == 1 && taskInfo.work_step >= NO_JOB)
		{
			// matrixPrint2(30, 440, taskInfo.worker_name, WHITE, 1);
			if (strcmp(prev_worker_name, taskInfo.worker_name) != 0)
			{
				ESP_LOGI(TAG, "%s %s", prev_worker_name, taskInfo.worker_name);
				memset(prev_worker_name, 0, sizeof(prev_worker_name));
				strcpy(prev_worker_name, taskInfo.worker_name);
				hangle_mem_write(taskInfo.worker_name, HG_MEM_WORKER); /* 한글 작업자 */
			}
			drawHangle(30, 425, taskInfo.worker_name, YELLOW, HG_MEM_WORKER);
		}
		else
		{
			EVE_cmd_text(100, 420, 31, 0, "---");
			taskInfo.work_step = NO_JOB_NO_WORKER;
		}

		/* 총 수 량 */
		EVE_cmd_setbitmap(mem_totalweight_addr, EVE_ARGB1555, 74, 42);
		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(300, 342));
		EVE_cmd_dl(DL_END);
		EVE_color_rgb(HIGH_LINE_COLOR, HIGH_LINE_COLOR, HIGH_LINE_COLOR);
		if (taskInfo.work_step <= NO_JOB)
		{
			EVE_cmd_text(559, 340, 31, 0, "-");
			taskInfo.total_weight = 0;
			taskInfo.current_product_cnt = 0;
			postData.weight = 0;
		}
		else
		{
			// EVE_cmd_number(559, 340, 31, 0, taskInfo.total_weight);
			// EVE_cmd_number(M3_LINE_X - 250, 340, 31, EVE_OPT_RIGHTX, taskInfo.current_product_cnt);
			memset(str, 0, sizeof(str));
			EVE_cmd_fgcolor(GRAY_2);
			sprintf(str, "%4d", taskInfo.current_product_cnt);
			EVE_cmd_button(M3_LINE_X - 365, 340, 110, 52, 31, EVE_OPT_FLAT | EVE_OPT_RIGHTX, str);

			memset(str, 0, sizeof(str));
			EVE_cmd_fgcolor(GRAY_1);
			sprintf(str, "%4d", taskInfo.production_total_cnt);
			EVE_cmd_button(M3_LINE_X - 245, 340, 110, 52, 31, EVE_OPT_FLAT | EVE_OPT_RIGHTX, str);

			EVE_color_rgb(0, 0, 0);
			EVE_cmd_fgcolor(WHITE_1);
			memset(str, 0, sizeof(str));
			sprintf(str, "%4d", taskInfo.work_quantity);
			EVE_cmd_button(M3_LINE_X - 125, 340, 110, 52, 31, EVE_OPT_FLAT | EVE_OPT_RIGHTX, str);
		}

		/* 작업 시간 */
		EVE_color_rgb(255, 255, 255);
		EVE_cmd_setbitmap(mem_totaltime_addr, EVE_ARGB1555, 153, 41);
		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(300, M1_LINE_Y + 20));
		EVE_cmd_dl(DL_END);

		// EVE_color_rgb(255, 255, 255);
		EVE_color_rgb(255, 0, 255);
		if (taskInfo.work_step <= NO_JOB)
		{
			EVE_cmd_text(556, 37, 31, EVE_OPT_CENTERX, "---");
		}
		else
		{
			if (strcmp(prev_work_name, taskInfo.work_name) != 0)
			{
				ESP_LOGI(TAG, "%d %s %s", memcmp(prev_work_name, taskInfo.worker_name, TASK_NAME_LENGTH), prev_work_name, taskInfo.work_name);
				memset(prev_work_name, 0, TASK_NAME_LENGTH);
				strcpy(prev_work_name, taskInfo.work_name);
				hangle_mem_write(taskInfo.work_name, HG_MEM_WORK_NAME); /* 한글 메모리 작업명 */
			}
			drawHangle(308, 40, taskInfo.work_name, PURPLE, HG_MEM_WORK_NAME);
		}
		EVE_color_rgb(255, 255, 255);
		/* 시계 */
		disp_time = scGetTime();
		if (disp_time.tm_year < (2016 - 1900))
		{
			EVE_cmd_text(31, 10, 30, 0, "----.--.--");
			EVE_cmd_text(28, 46, 31, 0, "--:--:--");
		}
		else
		{
			char day[32] = {
				0,
			};
			char tim[32] = {
				0,
			};
			sprintf(day, "%d.%2d.%2d.", disp_time.tm_year + 1900, disp_time.tm_mon, disp_time.tm_mday);
			sprintf(tim, "%d:%2d:%2d %s", disp_time.tm_hour % 12, disp_time.tm_min, disp_time.tm_sec, disp_time.tm_hour > 12 ? "PM" : "AM");
			EVE_cmd_text(28, 46, 31, 0, tim);
			EVE_cmd_text(31, 10, 30, 0, day);
			EVE_color_rgb(150, 150, 150);
			if (taskInfo.timeServerMode == TIME_SERVER_SNTP)
			{
				EVE_cmd_text(200, 10, 30, 0, "W");
			}
			else if (taskInfo.timeServerMode == TIME_SERVER_LOCAL)
			{
				EVE_cmd_text(200, 10, 30, 0, "L");
			}
		}

		/* 작업 시간 계산 표시 */
		EVE_color_rgb(GRAY_TEXT_COLOR, GRAY_TEXT_COLOR, GRAY_TEXT_COLOR);
		if (taskInfo.work_step <= NO_JOB || taskInfo.timeServerMode == TIME_SERVER_CONNECTING || taskInfo.timeServerMode == TIME_SERVER_NOT_FOUND)
		{
			EVE_cmd_text(540, 430, 31, 0, "--");
			EVE_cmd_text(600, 430, 31, 0, "--");
			worktime_start_hour = disp_time.tm_hour;
			worktime_start_min = disp_time.tm_min;
		}
		else
		{
			if (disp_time.tm_hour >= worktime_start_hour)
			{
				work_hours = disp_time.tm_hour - worktime_start_hour;
			}
			else
			{
				work_hours = (disp_time.tm_hour + 24) - worktime_start_hour;
			}
			if (disp_time.tm_min >= worktime_start_min)
			{

				work_min = disp_time.tm_min - worktime_start_min;
			}
			else
			{
				work_min = (disp_time.tm_min + 60) - worktime_start_min;
			}

			EVE_cmd_number(521, 430, 31, EVE_OPT_RIGHTX, work_hours);
			EVE_cmd_text(550, 430, 31, 0, "H");
			EVE_cmd_number(635, 430, 31, EVE_OPT_RIGHTX, work_min);
			EVE_cmd_text(650, 430, 31, 0, "M");
		}

		/* 아이콘 */
		EVE_color_rgb(255, 255, 255);
		EVE_cmd_dl(TAG(FAIL_WEIGHT));
		EVE_cmd_setbitmap(mem_bad_addr, EVE_ARGB1555, 50, 50);
		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(BUTTON_X, M1_LINE_Y - 50 - 30));
		EVE_cmd_dl(DL_END);

		/* 초기화 이이콘 */
		EVE_cmd_dl(TAG(SCALE_RESET));
		EVE_cmd_setbitmap(mem_reset_addr, EVE_ARGB1555, 50, 50);
		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(BUTTON_X, M1_LINE_Y + 20));
		EVE_cmd_dl(DL_END);

		/* 와이파이 아이콘 */
		EVE_cmd_dl(TAG(WIFI_SCAN));
		if (scaleInfo.wifi_status)
		{
			EVE_cmd_setbitmap(mem_wifi_full_addr, EVE_ARGB1555, 50, 50);
		}
		else
		{
			EVE_cmd_setbitmap(mem_wifi_discon_addr, EVE_ARGB1555, 50, 50);
		}

		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(BUTTON_X, M0_LINE_Y - 50 - 30));
		EVE_cmd_dl(DL_END);

		/* 영점 조절 아이콘*/
		EVE_cmd_dl(TAG(SCALE_CAL));
		EVE_cmd_setbitmap(mem_cal_addr, EVE_ARGB1555, 50, 50);
		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(BUTTON_X, M0_LINE_Y + 10));
		EVE_cmd_dl(DL_END);

		/*#### 마이너스 저울 저울 계산 #####*/
		if (scaleInfo.scale_mode == 1)
		{
			/* start 버튼 */
			EVE_cmd_dl(TAG(SCALE_START));
			EVE_cmd_setbitmap(mem_start_addr, EVE_ARGB1555, 50, 50);
			EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
			EVE_cmd_dl(VERTEX_FORMAT(0));
			EVE_cmd_dl(VERTEX2F(BUTTON_X, M0_LINE_Y + 50 + 20));
			EVE_cmd_dl(DL_END);

			EVE_cmd_romfont(1, 34);
			EVE_color_rgb(255, 255, 255);
			curGram = getUintValue();
			curGram = round(curGram); // 반올림
			intGram = (int32_t)curGram - taskInfo.bowl_weight;

			/* tag sound*/
			if (taskInfo.work_step == W_TAGGING_OK)
			{
				taskInfo.work_step = W_WAITING_START;
				EVE_sound_play(0x48, AUDIO_VOLUME); // debug
			}
			else if (taskInfo.work_step == W_TAGGING_ERR)
			{
				taskInfo.work_step = NO_JOB_NO_WORKER;
				EVE_sound_play(0x44, AUDIO_VOLUME);
			}

			if (taskInfo.work_step <= W_WAITING_START)
			{
				/* 노말 무게 표시 */
				fGram = ((float)intGram / 1000);
				sprintf(str, "%3.2f", fGram);
				EVE_cmd_text(M3_LINE_X - 120, 180, 1, EVE_OPT_RIGHTX, str);
			}
			else
			{
				/* 마이너스 무게 표시 */
				intGram = taskInfo.minusTotalWeight - intGram;
				fGram = ((float)intGram / 1000);
				sprintf(str, "%3.2f", fGram);
				EVE_cmd_text(M3_LINE_X - 120, 180, 1, EVE_OPT_RIGHTX, str);
			}

			if (taskInfo.stable_flag)
			{
				EVE_color_rgb(0, 0, 0);
				EVE_cmd_fgcolor(GREEN_1);
				EVE_cmd_button(300, 125, 100, 35, 29, EVE_OPT_FLAT | EVE_OPT_CENTERX, "STABLE");
			}
			if (taskInfo.zero_flag)
			{
				EVE_color_rgb(0, 0, 0);
				EVE_cmd_fgcolor(BLUE_1);
				EVE_cmd_button(410, 125, 100, 35, 29, EVE_OPT_FLAT | EVE_OPT_CENTERX, "ZERO");
			}
			if (taskInfo.bowl_flag)
			{
				EVE_color_rgb(0, 0, 0);
				EVE_cmd_fgcolor(YELLOW);
				EVE_cmd_button(520, 125, 100, 35, 29, EVE_OPT_FLAT | EVE_OPT_CENTERX, "BOWL");
			}

			/* 보조 무개 갯수 표시 */
			if (taskInfo.work_step > W_WAITING_START)
			{
				gDiff = taskInfo.target_weight - intGram;

				if (taskInfo.work_step == W_OVER)
				{
					EVE_color_rgb(255, 150, 150);
				}
				else if (taskInfo.work_step == W_UNDER)
				{
					EVE_color_rgb(150, 255, 150);
				}
				else
				{
					EVE_color_rgb(0, 0, 255);
				}
				fDiff = ((float)gDiff / 1000);
				sprintf(str, "%3.2f Kg", fDiff);
				EVE_cmd_text(160, 124, 30, EVE_OPT_RIGHTX, str);
				sprintf(str, "%d", gDiff / 100); // debug
				EVE_cmd_text(240, 124, 30, EVE_OPT_RIGHTX, str);
			}

			/* 메인 저울 g */
			EVE_color_rgb(150, 150, 150);
			EVE_cmd_text(M3_LINE_X - 60, 230, 1, EVE_OPT_CENTER, "Kg");

			/* 저울값표시 마이너스 저울  */
			if (taskInfo.work_step <= W_WAITING_START)
			{
				EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
				weight_cont_count = 0;
				sendLedDisp(LED_ALL_OFF, 10);
			}
			else if (taskInfo.work_step < W_POST)
			{
				if (taskInfo.work_step == W_CHEATING)
				{
					sendLedDisp(LED_G_ALL_ON, 10);
					taskInfo.work_step = W_POST;
				}
				else if (intGram <= taskInfo.max_weight && intGram >= taskInfo.min_weight && taskInfo.work_step != W_COMPLETE)
				{
					taskInfo.work_step = W_BAND_OK;
					// sendLedDisp(4, 10);
					sendSeqLed(weight_cont_count, taskInfo.w_passTime);
					weight_cont_count++;
					if (weight_cont_count > taskInfo.w_passTime && taskInfo.work_step != W_COMPLETE)
					{
						weight_cont_count = 0;
						taskInfo.work_step = W_COMPLETE;
						taskInfo.minusTotalWeight -= intGram;
						postData.weight = intGram;
						ESP_LOGI(TAG, "minus measure complete!");
					}
				}
				else if (intGram > taskInfo.max_weight)
				{
					sendLevelLed(intGram);
					taskInfo.work_step = W_OVER;
					weight_cont_count = 0;
				}
				else if (intGram < taskInfo.min_weight)
				{
					sendLevelLed(intGram);
					taskInfo.work_step = W_UNDER;
					weight_cont_count = 0;
				}

				/* bmp 상태 표시*/
				if (taskInfo.work_step == W_COMPLETE)
				{
					EVE_cmd_setbitmap(mem_greenchk_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_COMPLETE");
				}
				else if (taskInfo.work_step == W_OVER)
				{
					EVE_cmd_setbitmap(mem_red_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_OVER");
				}
				else if (taskInfo.work_step == W_UNDER)
				{
					EVE_cmd_setbitmap(mem_blue_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_UNDER");
				}
				else if (taskInfo.work_step == W_BAND_OK)
				{
					EVE_cmd_setbitmap(mem_greenchk_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_BAND_OK");
				}
				else if (taskInfo.work_step == W_CHEATING)
				{
					EVE_cmd_setbitmap(mem_greenchk_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_CHEATING");
				}
				else
				{
					EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "MEM_BMP_NOMAL");
				}
			}
			else
			{
				sendLevelLed(intGram);
				EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
				// ESP_LOGI(TAG, "MEM_BMP_NOMAL??");
			}

			/* 저울값표시 플러스 저울  */
			if (taskInfo.work_step <= NO_JOB)
			{
				EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
				weight_cont_count = 0;
				sendLedDisp(LED_ALL_OFF, 10);
			}
		}
		else
		{
			/*#### 플러스 저울 계산 #####*/

			/* 저울 */
			EVE_cmd_romfont(1, 34);
			EVE_color_rgb(255, 255, 255);
			curGram = getUintValue();
			curGram = round(curGram); // 반올림
			intGram = (int32_t)(curGram - taskInfo.bowl_weight);

			/* 무게 표시 */
			fGram = ((float)intGram / 1000);
			sprintf(str, "%3.2f", fGram);
			EVE_cmd_text(M3_LINE_X - 120, 180, 1, EVE_OPT_RIGHTX, str);
			if (taskInfo.stable_flag)
			{
				EVE_color_rgb(0, 0, 0);
				EVE_cmd_fgcolor(GREEN_1);
				EVE_cmd_button(300, 125, 100, 35, 29, EVE_OPT_FLAT | EVE_OPT_CENTERX, "STABLE");
			}
			if (taskInfo.zero_flag)
			{
				EVE_color_rgb(0, 0, 0);
				EVE_cmd_fgcolor(BLUE_1);
				EVE_cmd_button(410, 125, 100, 35, 29, EVE_OPT_FLAT | EVE_OPT_CENTERX, "ZERO");
			}
			if (taskInfo.bowl_flag)
			{
				EVE_color_rgb(0, 0, 0);
				EVE_cmd_fgcolor(YELLOW);
				EVE_cmd_button(520, 125, 100, 35, 29, EVE_OPT_FLAT | EVE_OPT_CENTERX, "BOWL");
			}
			if (taskInfo.work_step == W_TAGGING_OK)
			{
				taskInfo.work_step = W_START;
				EVE_sound_play(0x47, AUDIO_VOLUME);
			}
			else if (taskInfo.work_step == W_TAGGING_ERR)
			{
				taskInfo.work_step = NO_JOB_NO_WORKER;
				EVE_sound_play(0x44, AUDIO_VOLUME);
			}
			/* 보조 무개 갯수 표시 */
			if (taskInfo.work_step > NO_JOB)
			{
				gDiff = intGram - taskInfo.target_weight;
				if (taskInfo.work_step == W_OVER)
				{
					EVE_color_rgb(255, 150, 150);
				}
				else if (taskInfo.work_step == W_UNDER)
				{
					EVE_color_rgb(150, 255, 150);
				}
				else
				{
					EVE_color_rgb(0, 0, 255);
				}

				fDiff = ((float)gDiff / 1000);
				sprintf(str, "%3.2f Kg", fDiff);
				EVE_cmd_text(160, 124, 30, EVE_OPT_RIGHTX, str);
				sprintf(str, "%d", gDiff / 100); // debug
				EVE_cmd_text(240, 124, 30, EVE_OPT_RIGHTX, str);
			}

			EVE_color_rgb(150, 150, 150);
			EVE_cmd_text(M3_LINE_X - 60, 230, 1, EVE_OPT_CENTER, "Kg");

			/* 저울값표시 플러스 저울  */
			if (taskInfo.work_step <= NO_JOB)
			{
				EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
				weight_cont_count = 0;
				sendLedDisp(LED_ALL_OFF, 10);
			}
			else if (taskInfo.work_step < W_POST)
			{
				if (taskInfo.work_step == W_CHEATING)
				{
					sendLedDisp(LED_G_ALL_ON, 10);
					int32_t tmp_g = taskInfo.target_weight / 10;
					if (intGram < tmp_g && intGram >= -(taskInfo.bowl_weight + tmp_g))
					{
						taskInfo.work_step = W_POST;
					}
					//ESP_LOGI(TAG, "W_CHEATING %d", taskInfo.stable_flag);
				}
				else if (intGram <= taskInfo.max_weight && intGram >= taskInfo.min_weight && taskInfo.work_step != W_COMPLETE)
				{
					taskInfo.work_step = W_BAND_OK;
					sendLedDisp(4, 10);
					// sendSeqLed_plus(weight_cont_count, taskInfo.w_passTime);
					weight_cont_count++;
					if (weight_cont_count > taskInfo.w_passTime && taskInfo.work_step != W_COMPLETE)
					{
						int32_t tmp = _1sec_count - cheatCount;
						if (tmp > taskInfo.cheatingTimeout || cheat_g != intGram)
						{
							/* 치팅 타임아웃 이전에 다른값이 들어오거나 타이아웃이 되거나*/
							sendLedDisp(LED_G_ALL_ON, 10);
							taskInfo.work_step = W_COMPLETE;
							postData.weight = intGram;
							cheat_g = intGram;
							cheatCount = _1sec_count;
							//ESP_LOGI(TAG, "measure complete!");
						}
						else
						{
							weight_cont_count = 0;
							//ESP_LOGI(TAG, "cheatting!!");
						}
					}
				}
				else if (intGram > taskInfo.max_weight && intGram >= 0)
				{
					sendLevelLed(intGram);
					taskInfo.work_step = W_OVER;
					weight_cont_count = 0;
				}
				else if (intGram < taskInfo.min_weight)
				{
					sendLevelLed(intGram);
					taskInfo.work_step = W_UNDER;
					weight_cont_count = 0;
				}

				/* bmp 상태 표시*/
				if (taskInfo.work_step == W_COMPLETE)
				{
					EVE_cmd_setbitmap(mem_greenchk_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_COMPLETE");
				}
				else if (taskInfo.work_step == W_OVER)
				{
					EVE_cmd_setbitmap(mem_red_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_OVER");
				}
				else if (taskInfo.work_step == W_UNDER)
				{
					EVE_cmd_setbitmap(mem_blue_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_UNDER");
				}
				else if (taskInfo.work_step == W_BAND_OK)
				{
					EVE_cmd_setbitmap(mem_greenchk_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_BAND_OK");
				}
				else if (taskInfo.work_step == W_CHEATING)
				{
					EVE_cmd_setbitmap(mem_greenchk_addr, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "W_CHEATING");
				}
				else
				{
					EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
					// ESP_LOGI(TAG, "MEM_BMP_NOMAL");
				}
			}
			else
			{
				sendLevelLed(intGram);
				EVE_cmd_setbitmap(MEM_BMP_NOMAL, EVE_ARGB1555, 200, 220);
				// ESP_LOGI(TAG, "MEM_BMP_NOMAL??");
			}
		}

		EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
		EVE_cmd_dl(VERTEX_FORMAT(0));
		EVE_cmd_dl(VERTEX2F(30, 165));
		EVE_cmd_dl(DL_END);

		new_offset = EVE_report_cmdoffset();
		if (old_offset > new_offset)
		{
			new_offset += 4096;
		}
		calc = new_offset - old_offset;
		calc += 24; /* adjust for the commands that follow before the end */
		// EVE_cmd_number(120, EVE_VSIZE - 50, 26, EVE_OPT_RIGHTX, calc); /* number of bytes written to the cmd-fifo over the spi without addressing overhead */

		EVE_cmd_dl(DL_DISPLAY); /* instruct the graphics processor to show the list */
		EVE_cmd_dl(CMD_SWAP);	/* make this list active */

		EVE_end_cmd_burst(); /* stop writing to the cmd-fifo */
		EVE_cmd_start();	 /* order the command co-processor to start processing its FIFO queue but do not wait for completion */
	}
	return;
}

void ui_reset(void)
{
	uint16_t But_opt;
	static uint16_t old_offset, new_offset;
	uint32_t calc;

	EVE_start_cmd_burst(); /* start writing to the cmd-fifo as one stream of bytes, only sending the address once */

	EVE_cmd_dl(CMD_DLSTART); /* start the display list */
	EVE_cmd_dl(VERTEX_FORMAT(0));

	EVE_cmd_dl(DL_CLEAR_RGB | WHITE);					/* set the default clear color to white */
	EVE_cmd_dl(DL_CLEAR | CLR_COL | CLR_STN | CLR_TAG); /* clear the screen - this and the previous prevent artifacts between lists, Attributes are the color, stencil and tag buffers */
	// EVE_cmd_bgcolor(0x0000a2e8);

	EVE_cmd_setbitmap(mem_hg_init_addr, EVE_ARGB1555, 341, 50); // 188, 'x', 64,
	EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
	EVE_cmd_dl(VERTEX_FORMAT(0));
	EVE_cmd_dl(VERTEX2F(239, 156));
	EVE_cmd_dl(DL_END);
	// EVE_color_rgb(100, 255, 100);
	// EVE_cmd_text(EVE_HSIZE * 0.4, EVE_VSIZE * 0.5, 33, EVE_OPT_CENTER, "Work Complete!");
	EVE_cmd_fgcolor(0x505050);
	EVE_cmd_bgcolor(0x505050);

	But_opt = (initTouchTag == INIT_CANCLE) ? EVE_OPT_FLAT : 0;
	EVE_cmd_dl(TAG(INIT_CANCLE));
	EVE_cmd_button(245, 290, 160, 60, 30, But_opt, "Cancle");

	// ESP_LOGI(TAG, "%d(%d)", But_opt, initTouchTag);
	But_opt = (initTouchTag == INIT_OK) ? EVE_OPT_FLAT : 0;
	EVE_cmd_dl(TAG(INIT_OK));
	EVE_cmd_button(440, 290, 160, 60, 30, But_opt, "OK");

	new_offset = EVE_report_cmdoffset();
	if (old_offset > new_offset)
	{
		new_offset += 4096;
	}
	calc = new_offset - old_offset;
	calc += 24; /* adjust for the commands that follow before the end */

	EVE_cmd_dl(DL_DISPLAY); /* instruct the graphics processor to show the list */
	EVE_cmd_dl(CMD_SWAP);	/* make this list active */

	EVE_end_cmd_burst(); /* stop writing to the cmd-fifo */
	EVE_cmd_start();	 /* order the command co-processor to start processing its FIFO queue but do not wait for completion */

	return;
}

void initCallback(UI_INIT_EVENT event)
{
	switch (event)
	{
	case INIT_CANCLE:
		EVE_sound_play(AUDIO_CLICK, AUDIO_VOLUME);
		newScenario = MAIN_SCALE_SCENARIO;
		break;
	case INIT_OK:
		EVE_sound_play(AUDIO_CLICK, AUDIO_VOLUME);
		taskInfo.work_seq = 0;
		taskInfo.work_quantity = 0;
		taskInfo.production_total_cnt = 0;
		taskInfo.current_product_cnt = 0;
		taskInfo.bowl_weight = 0;
		taskInfo.work_step = NO_JOB_NO_WORKER;
		newScenario = MAIN_SCALE_SCENARIO;
		taskInfo.minusTotalWeight = 0;
		break;
	default:
		break;
	}
}

void initScreenLoop()
{
	uint8_t TouchTag = TouchInput();
	uint8_t tagFlag = 0;
	static uint8_t preTag = 0;

	initTouchTag = TouchTag;
	if (preTag != TouchTag)
	{
		if (TouchTag == 0)
		{
			tagFlag = 1;
		}
		else
		{
			preTag = TouchTag;
		}
	}

	if (preTag >= INIT_CANCLE && preTag <= INIT_OK && tagFlag)
	{
		tagFlag = 0;
		// ESP_LOGI(TAG, "reset (%d)", TouchTag);
		(*init_callback)(preTag);
		preTag = 0;
	}
	ui_reset();
}
/***
 *  작업미등록 화면 출력
 ***/
void unReg_Callback(MSG_UN_REG event)
{
	switch (event)
	{
	case UNREG_OK:
		EVE_sound_play(AUDIO_CLICK, AUDIO_VOLUME);
		newScenario = MAIN_SCALE_SCENARIO;
		break;
	default:
		break;
	}
}

void unRegScreenLoop()
{
	uint8_t TouchTag = TouchInput();
	static uint8_t preTag = 0;

	if (preTag != TouchTag)
	{
		preTag = TouchTag;
		ESP_LOGI(TAG, "unreg tag = %d", TouchTag);
	}

	if (TouchTag == UNREG_OK)
	{
		ESP_LOGI(TAG, "unreg (%d)", TouchTag);
		(*unRegCallback)(TouchTag);
	}
	msgWorkUnRegScreen();
}

void msgWorkUnRegScreen(void)
{
	// uint8_t But_opt;
	static uint16_t old_offset, new_offset;
	uint32_t calc;

	EVE_start_cmd_burst(); /* start writing to the cmd-fifo as one stream of bytes, only sending the address once */

	EVE_cmd_dl(CMD_DLSTART); /* start the display list */
	EVE_cmd_dl(VERTEX_FORMAT(0));

	EVE_cmd_dl(DL_CLEAR_RGB | MSG_GRN);					/* set the default clear color to white */
	EVE_cmd_dl(DL_CLEAR | CLR_COL | CLR_STN | CLR_TAG); /* clear the screen - this and the previous prevent artifacts between lists, Attributes are the color, stencil and tag buffers */

	EVE_cmd_setbitmap(mem_hg_unreg_addr, EVE_ARGB1555, 202, 55); // 188, 'x', 64,
	EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
	EVE_cmd_dl(VERTEX_FORMAT(0));
	EVE_cmd_dl(VERTEX2F(283, 139));
	EVE_cmd_dl(DL_END);
	EVE_cmd_fgcolor(0x505050);
	EVE_cmd_bgcolor(0x505050);

	EVE_cmd_dl(TAG(UNREG_OK));
	EVE_cmd_button(291, 284, 160, 60, 30, EVE_OPT_CENTER, "OK");

	new_offset = EVE_report_cmdoffset();
	if (old_offset > new_offset)
	{
		new_offset += 4096;
	}
	calc = new_offset - old_offset;
	calc += 24; /* adjust for the commands that follow before the end */

	EVE_cmd_dl(DL_DISPLAY); /* instruct the graphics processor to show the list */
	EVE_cmd_dl(CMD_SWAP);	/* make this list active */

	EVE_end_cmd_burst(); /* stop writing to the cmd-fifo */
	EVE_cmd_start();	 /* order the command co-processor to start processing its FIFO queue but do not wait for completion */

	return;
}
/***
 *  작업시작 화면 출력
 ***/
void start_Callback(MSG_START event)
{
	float curGram, intGram;

	switch (event)
	{
	case START_OK:
		EVE_sound_play(AUDIO_CLICK, AUDIO_VOLUME);
		curGram = getUintValue();
		intGram = (int32_t)curGram - taskInfo.bowl_weight;
		if (intGram > taskInfo.max_weight)
		{
			taskInfo.work_step = W_START;
			taskInfo.minusTotalWeight = intGram;
		}
		else
		{
			ESP_LOGI(TAG, "저울이 비었슴");
		}
		newScenario = MAIN_SCALE_SCENARIO;
		break;

	default:
		break;
	}
}

void startScreenLoop()
{
	uint8_t TouchTag = TouchInput();
	static uint8_t preTag = 0;
	static uint8_t prevStartKey = 0;

	/*ext  key input */
	uint8_t startKey = gpio_get_level(GPIO_NUM_2);

	if (startKey != prevStartKey)
	{
		prevStartKey = startKey;
		if (startKey)
		{
			TouchTag = START_OK;
			ESP_LOGI(TAG, "press start key!(%d)", startKey);
		}
		else
		{
		}
	}

	if (preTag != TouchTag)
	{
		preTag = TouchTag;
		ESP_LOGI(TAG, "start tag = %d", TouchTag);
	}

	if (TouchTag == START_OK)
	{
		ESP_LOGI(TAG, "unreg (%d)", TouchTag);
		(*startCallback)(TouchTag);
	}
	msgStartScreen();
}

void msgStartScreen(void)
{
	// uint8_t But_opt;
	static uint16_t old_offset, new_offset;
	uint32_t calc;

	EVE_start_cmd_burst(); /* start writing to the cmd-fifo as one stream of bytes, only sending the address once */

	EVE_cmd_dl(CMD_DLSTART); /* start the display list */
	EVE_cmd_dl(VERTEX_FORMAT(0));

	EVE_cmd_dl(DL_CLEAR_RGB | START);					/* set the default clear color to white */
	EVE_cmd_dl(DL_CLEAR | CLR_COL | CLR_STN | CLR_TAG); /* clear the screen - this and the previous prevent artifacts between lists, Attributes are the color, stencil and tag buffers */

	EVE_cmd_setbitmap(mem_work_start_addr, EVE_ARGB1555, 162, 54); // 188, 'x', 64,
	EVE_cmd_dl(DL_BEGIN | EVE_BITMAPS);
	EVE_cmd_dl(VERTEX_FORMAT(0));
	EVE_cmd_dl(VERTEX2F(333, 157));
	EVE_cmd_dl(DL_END);
	EVE_cmd_fgcolor(0x505050);
	EVE_cmd_bgcolor(0x505050);

	EVE_cmd_dl(TAG(START_OK));
	EVE_cmd_button(353, 274, 160, 60, 30, EVE_OPT_CENTER, "OK");

	new_offset = EVE_report_cmdoffset();
	if (old_offset > new_offset)
	{
		new_offset += 4096;
	}
	calc = new_offset - old_offset;
	calc += 24; /* adjust for the commands that follow before the end */

	EVE_cmd_dl(DL_DISPLAY); /* instruct the graphics processor to show the list */
	EVE_cmd_dl(CMD_SWAP);	/* make this list active */

	EVE_end_cmd_burst(); /* stop writing to the cmd-fifo */
	EVE_cmd_start();	 /* order the command co-processor to start processing its FIFO queue but do not wait for completion */

	return;
}
// 시작 메세지
void *msg_start_start(void (*touchcallback)(MSG_START event))
{
	startCallback = touchcallback;

	return startScreenLoop;
}
// 미등록 메세지
void *msg_unreg_start(void (*touchcallback)(MSG_UN_REG event))
{
	unRegCallback = touchcallback;

	return unRegScreenLoop;
}
// 초기화 메뉴 화면
void *ui_init_start(void (*touchcallback)(UI_INIT_EVENT event))
{
	init_callback = touchcallback;
	return initScreenLoop;
}

void EVE_bitmap_load(void)
{
	/* intro display off */
	EVE_cmd_dl(CMD_DLSTART);
	EVE_cmd_bgcolor(BLACK);
	EVE_cmd_dl(DL_DISPLAY); /* instruct the graphics processor to show the list */
	EVE_cmd_dl(CMD_SWAP);	/* make this list active */
	EVE_cmd_execute();

	/*----indigator---*/
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_NOMAL));
	EVE_cmd_inflate(MEM_BMP_NOMAL, bmp_nomal, sizeof(bmp_nomal));

	mem_greenchk_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_GREENCHK));
	EVE_cmd_inflate(mem_greenchk_addr, green_check, sizeof(green_check));
	ESP_LOGI(TAG, "mem_greenchk_addr = 0x%x", mem_greenchk_addr);

	mem_red_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_RED));
	EVE_cmd_inflate(mem_red_addr, bmp_red, sizeof(bmp_red));
	ESP_LOGI(TAG, "mem_red_addr = 0x%x", mem_red_addr);

	mem_blue_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_BLUE));
	EVE_cmd_inflate(mem_blue_addr, bmp_blue, sizeof(bmp_blue));
