	ESP_LOGI(TAG, "mem_work_end_addr = 0x%x", mem_work_end_addr);

	mem_hg_head_org_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_HEAD_ORG));
	EVE_cmd_inflate(mem_hg_head_org_addr, bmp_hg_head_org, sizeof(bmp_hg_head_org));
	ESP_LOGI(TAG, "mem_hg_head_org_addr = 0x%x", mem_hg_head_org_addr);

	mem_hg_100g_addr = EVE_cmd_getptr();
