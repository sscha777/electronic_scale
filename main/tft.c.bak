	ESP_LOGI(TAG, "mem_hg_unreg_addr = 0x%x", mem_hg_unreg_addr);

	mem_hg_init_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_INIT));
	EVE_cmd_inflate(mem_hg_init_addr, bmp_hg_init, sizeof(bmp_hg_init));
	ESP_LOGI(TAG, "mem_hg_init_addr = 0x%x", mem_hg_init_addr);

	mem_ui_fail_addr = EVE_cmd_getptr();
	EVE_cmd_dl(BITMAP_HANDLE(GMAIN_HANDLE_UI_FAIL));
	EVE_cmd_inflate(mem_ui_fail_addr, bmp_ui_fail, sizeof(bmp_ui_fail));
	ESP_LOGI(TAG, "mem_ui_fail_addr = 0x%x", mem_ui_fail_addr);

	mem_hangle_font = EVE_cmd_getptr();
	ESP_LOGI(TAG, "mem_hangle_font = 0x%x", mem_hangle_font);

	uint32_t w, h;
	EVE_LIB_GetProps(&mem_hangle_font_img, &w, &h);
	ESP_LOGI(TAG, "mem_hangle_font_img = 0x%x, %d,%d", mem_hangle_font_img, w, h);

	return;
}
